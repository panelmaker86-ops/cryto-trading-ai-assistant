# Strategy Guardian AI - Environment Template
# Copy to .env and fill in your values. Never commit .env.

# ----- Exchange (use one or both) -----
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# ----- Alerts -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DISCORD_WEBHOOK_URL=

# ----- Data -----
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/guardian
REDIS_URL=redis://localhost:6379/0

# ----- App -----
APP_ENV=development
LOG_LEVEL=INFO

# ----- Risk defaults (overridable per user) -----
DEFAULT_MAX_RISK_PER_TRADE_PCT=3.0
DEFAULT_MAX_DAILY_LOSS_PCT=5.0
DEFAULT_MAX_LEVERAGE=10
